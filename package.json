{
  "name": "dalaillma",
  "version": "1.0.0",
  "description": "LLM Conversation Sentiment Dashboard - Visualize patterns from Claude and ChatGPT exports",
  "main": "scripts/process_data.js",
  "scripts": {
    "setup": "mkdir -p data/anthropic data/openai output",
    "process": "node scripts/process_data.js",
    "analyze": "node scripts/analyze_all.js",
    "analyze:force": "node scripts/analyze_all.js --force",
    "build": "node scripts/build_dashboard.js",
    "all": "npm run process && npm run build",
    "full": "npm run process && npm run analyze && npm run build",
    "serve": "npx serve . -p 3000",
    "test": "node verify_dashboard.js"
  },
  "keywords": [
    "llm",
    "sentiment-analysis",
    "dashboard",
    "claude",
    "chatgpt",
    "wellbeing",
    "conversation-analysis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
